# ── Supabase ──────────────────────────────────────────────────────────────────
# Copiá este archivo a .env (o .env.local) y completá con valores reales.
# NUNCA pongas claves reales acá: este archivo está versionado en git.

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Settings → API Keys. Aunque Supabase muestre una key nueva
# (sb_publishable_...), el proyecto la espera bajo esta variable.
# También acepta la anon key legacy (eyJ...).
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_REEMPLAZAR_CON_TU_KEY

# Clave privada: SOLO backend, nunca en el navegador ni en git.
# El proyecto la espera bajo esta variable, acepte una secret key nueva
# (sb_secret_...) o la service_role legacy (eyJ...).
SUPABASE_SERVICE_ROLE_KEY=REEMPLAZAR_CON_TU_SECRET_O_SERVICE_ROLE_KEY


# ── Aplicación ────────────────────────────────────────────────────────────────
# URL pública de la app (para armar links de QR). En local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Elegí una contraseña real para entrar a /admin.
ADMIN_PASSWORD=REEMPLAZAR_CON_UNA_CLAVE_SEGURA
# Secreto aleatorio de al menos 32 caracteres para firmar la cookie de sesión.
SESSION_SECRET=REEMPLAZAR_CON_UN_SECRETO_ALEATORIO_LARGO


# ── WhatsApp Cloud API (opcional — sin esto funciona el modo simulado) ────────
# Ver docs/WHATSAPP.md. Por ahora vacío = la app usa el modo simulado.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_TEMPLATE_NAME=
