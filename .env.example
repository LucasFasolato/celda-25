# ── Supabase ──────────────────────────────────────────────────────────────────
# Proyecto Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon...
# Service role: SOLO backend. Nunca exponer.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# ── Aplicación ────────────────────────────────────────────────────────────────
# URL pública de la app (para armar links de QR). En local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambiar-esta-clave
# Secreto para firmar la cookie de sesión (32+ chars aleatorios)
SESSION_SECRET=cambiar-por-un-secreto-largo-y-aleatorio

# ── WhatsApp Cloud API (opcional — sin esto funciona el modo simulado) ────────
# Ver docs/WHATSAPP.md para obtener estos valores.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0
# Nombre de plantilla aprobada (si Meta exige plantilla para iniciar conversación)
WHATSAPP_TEMPLATE_NAME=
